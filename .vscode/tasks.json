{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build: Prowl.Editor Debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Prowl.Editor/Prowl.Editor.csproj",
                "-c", "Debug"
            ],
            "group": "build",
            "presentation": { "reveal": "silent" },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build: Prowl.Editor Release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Prowl.Editor/Prowl.Editor.csproj",
                "-c", "Release"
            ],
            "group": "build",
            "presentation": { "reveal": "silent" },
            "problemMatcher": "$msCompile"
        }
    ]
}
